{
  "name": "mddg",
  "version": "1.0.0",
  "description": "Markdown → DOCX, PDF, HTML, and presentation builder for developers and AI agents. Write documents in Markdown, compile to professional Word documents, PDFs, and more.",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./canvas-utils": "./src/canvas-utils.js"
  },
  "bin": {
    "mddg": "./bin/mdoc.js"
  },
  "files": [
    "src/",
    "bin/",
    "README.md",
    "USAGE.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/mdoc.js",
    "lint": "eslint src/ bin/",
    "lint:fix": "eslint src/ bin/ --fix",
    "test": "node --test src/**/*.test.js 2>/dev/null || echo 'No tests yet'",
    "validate": "node bin/mdoc.js validate",
    "build:example": "node bin/mdoc.js --no-pdf projects/these-hmh2",
    "build:example:pdf": "node bin/mdoc.js projects/these-hmh2",
    "prepublishOnly": "pnpm run lint"
  },
  "keywords": [
    "markdown",
    "docx",
    "pdf",
    "html",
    "presentation",
    "slides",
    "word",
    "document",
    "builder",
    "generator",
    "ai",
    "agent",
    "template",
    "report",
    "thesis"
  ],
  "author": "vinodnal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vinodnal/mddg.git"
  },
  "homepage": "https://github.com/vinodnal/mddg#readme",
  "bugs": {
    "url": "https://github.com/vinodnal/mddg/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "canvas": "^3.2.3",
    "chokidar": "^4.0.3",
    "docx": "^9.6.1"
  },
  "optionalDependencies": {
    "temml": "^0.10.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-n": "^17.0.0"
  }
}
